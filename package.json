{
  "name": "@kommo-crm/linting-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Kommo shared linting packages",
  "license": "MIT",
  "author": "Kommo",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo build",
    "dev": "pnpm --filter @kommo-crm/eslint-config dev",
    "typecheck": "turbo typecheck",
    "lint": "eslint . --concurrency=1",
    "lint:fix": "eslint . --fix --concurrency=1",
    "knip": "turbo knip",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "format": "prettier --write .",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.0",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/js": "9.34.0",
    "eslint": "9.34.0",
    "globals": "15.0.0",
    "husky": "9.1.7",
    "lint-staged": "15.0.0",
    "prettier": "3.3.3",
    "turbo": "2.9.16",
    "typescript-eslint": "7.17.0"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
