{
  "name": "@kommo-crm/eslint-plugin",
  "version": "0.1.0",
  "description": "Custom ESLint rules for Kommo projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kommo-crm/linting.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/kommo-crm/linting/issues"
  },
  "homepage": "https://github.com/kommo-crm/linting#readme",
  "author": "Kommo",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "node --import tsx --test \"__tests__/**/*.test.ts\"",
    "test:coverage": "c8 --config .c8rc.json node --import tsx --test \"__tests__/**/*.test.ts\""
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "c8": "11.0.0",
    "eslint": "9.34.0",
    "knip": "6.6.0",
    "tsup": "8.0.0",
    "tsx": "4.7.0",
    "typescript": "5.5.4"
  }
}
