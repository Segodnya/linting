{
  "name": "@kommo-crm/eslint-config",
  "version": "0.1.0",
  "description": "Shared ESLint configuration for Kommo projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kommo-crm/linting.git",
    "directory": "packages/eslint-config"
  },
  "bugs": {
    "url": "https://github.com/kommo-crm/linting/issues"
  },
  "homepage": "https://github.com/kommo-crm/linting#readme",
  "author": "Kommo",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./legacy": "./dist/legacy.cjs",
    "./types": "./dist/types/global.d.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs && node scripts/build-legacy.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "node --import tsx --test \"__tests__/**/*.test.ts\"",
    "test:coverage": "c8 --config .c8rc.json node --import tsx --test \"__tests__/**/*.test.ts\"",
    "test:snapshot:update": "node --import tsx scripts/snapshot-update.mjs"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@kommo-crm/eslint-plugin": "workspace:*",
    "@eslint/js": "9.34.0",
    "@stylistic/eslint-plugin": "2.6.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsdoc": "48.2.3",
    "eslint-plugin-only-var": "0.1.2",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.8.1",
    "globals": "15.0.0",
    "typescript-eslint": "7.17.0"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "@types/react": "19.2.14",
    "c8": "11.0.0",
    "eslint": "9.34.0",
    "knip": "6.6.0",
    "prettier": "3.3.3",
    "tsup": "8.0.0",
    "tsx": "4.7.0",
    "typescript": "5.5.4"
  }
}
